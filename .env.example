# ============================================
# Yandex Disk Telegram Bot - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# --- Required: Telegram Bot Token ---
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token

# --- Required: Yandex Disk OAuth Token ---
# Get from https://oauth.yandex.ru/
YANDEX_DISK_TOKEN=your_yandex_disk_token

# --- Required: Admin Telegram User ID ---
# Get your ID from @userinfobot on Telegram
ADMIN_ID=123456789

# --- Optional: Database file name ---
# Default: bot_database.db
DB_NAME=bot_database.db

# --- Optional: Root folder on Yandex Disk ---
# Default: Фото из телеграмма
ROOT_FOLDER=Фото из телеграмма

# --- Optional: Max concurrent uploads ---
# Default: 5
MAX_CONCURRENT_UPLOADS=5

# --- Optional: Log level ---
# Values: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# --- Optional: Web server settings (for Render.com) ---
# Render.com sets PORT automatically, default for local: 10000
PORT=10000